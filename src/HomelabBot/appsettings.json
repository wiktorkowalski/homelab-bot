{
  "Serilog": {
    "Using": [
      "Serilog.Sinks.Console"
    ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning",
        "DSharpPlus": "Warning",
        "Polly": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "outputTemplate": "{Timestamp:HH:mm:ss} [{Level:u3}] {SourceContext}: {Message:lj}{NewLine}{Exception}"
        }
      }
    ],
    "Enrich": [
      "FromLogContext"
    ]
  },
  "Bot": {
    "DiscordToken": "",
    "OpenRouterApiKey": "",
    "OpenRouterModel": "moonshotai/kimi-k2.6",
    "OpenRouterEndpoint": "https://openrouter.ai/api/v1",
    "DedicatedChannels": [],
    "ExternalUrls": {
      "grafana": "https://grafana.home.vicio.ovh",
      "prometheus": "https://prometheus.home.vicio.ovh",
      "alertmanager": "https://alertmanager.home.vicio.ovh"
    }
  },
  "MikroTik": {
    "Host": "http://192.168.1.1",
    "ApiPort": 8728,
    "Username": "prometheus",
    "Password": ""
  },
  "TrueNAS": {
    "Host": "http://192.168.1.6",
    "ApiKey": ""
  },
  "HomeAssistant": {
    "Host": "http://192.168.1.8:8123",
    "AccessToken": ""
  },
  "Prometheus": {
    "Host": "http://prometheus:9090"
  },
  "Grafana": {
    "Host": "http://grafana:3000",
    "ApiKey": ""
  },
  "Alertmanager": {
    "Host": "http://alertmanager:9093"
  },
  "Loki": {
    "Host": "http://loki:3100"
  },
  "Ntfy": {
    "Host": "http://ntfy:80",
    "DefaultTopic": "alerts"
  },
  "Langfuse": {
    "Endpoint": "http://langfuse:3000/api/public/otel/v1/traces",
    "PublicKey": "",
    "SecretKey": ""
  },
  "DailySummary": {
    "Enabled": true,
    "ScheduleTime": "08:00",
    "TimeZone": "Europe/Warsaw"
  },
  "AlertWebhook": {},
  "HealthScore": {
    "Enabled": true,
    "IntervalMinutes": 15,
    "AlertDropThreshold": 15
  },
  "AnomalyDetection": {
    "Enabled": true,
    "HeuristicIntervalMinutes": 60,
    "LlmIntervalTicks": 1
  },
  "SecurityAudit": {
    "Enabled": true,
    "ScheduleDay": "Sunday",
    "ScheduleTime": "04:00",
    "TimeZone": "Europe/Warsaw"
  },
  "LogAnomaly": {
    "Enabled": true,
    "IntervalMinutes": 30,
    "ErrorThreshold": 50
  },
  "KnowledgeRefresh": {
    "Enabled": true,
    "ScheduleTime": "05:00",
    "TimeZone": "Europe/Warsaw",
    "NotifyOnChanges": true
  },
  "AutoRemediation": {
    "Enabled": true,
    "MinSuccessRate": 80,
    "MinFeedbackCount": 3,
    "MaxRestartsPerHour": 3
  },
  "McpServer": {
    "Enabled": false,
    "ApiKey": ""
  }
}
